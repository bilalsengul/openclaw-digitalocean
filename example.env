# ═══════════════════════════════════════════════════════════════════
# 🦞 OpenClaw — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
#
# HOW TO USE:
#   1. Copy this file:       cp example.env .env
#   2. Fill in your values below
#   3. Deploy:               Provide install.md to your AI agent
#
# ═══════════════════════════════════════════════════════════════════


# ─── Project Identity (required) ────────────────────────────────
# These define YOUR project — the Droplet name, what repo to clone,
# and where to install it on the server.
#
PROJECT_NAME=my-openclaw-project
PROJECT_REPO=https://github.com/your-org/your-repo.git
REMOTE_DIR=/opt/openclaw


# ─── DigitalOcean API (required for install.sh) ─────────────────
# The DigitalOcean API token lets the AI Agent (via install.md) create, configure,
# and manage your Droplet automatically. Without it, you'd need
# to create the Droplet manually in the DO console.
#
# How to get it:
#   1. Log in to https://cloud.digitalocean.com
#   2. Go to API → Tokens (left sidebar)
#   3. Click "Generate New Token"
#   4. Name it (e.g. "openclaw-deploy"), select Full Access
#   5. Copy the token — it's only shown once!
#
# Not needed if you deploy manually (e.g., docker compose on
# your own server).
#
DO_API_TOKEN=


# ─── OpenClaw Version ───────────────────────────────────────────
# Pin the OpenClaw version to avoid breaking changes.
# Check releases: https://github.com/openclaw/openclaw/releases
#
OPENCLAW_VERSION=2026.2.15


# ─── Gradient AI (recommended) ──────────────────────────────────
# Gradient AI is DigitalOcean's serverless AI inference platform.
# One API key gives you access to 29 models — including
# open-source models (Llama, DeepSeek, Qwen, GPT OSS) and
# commercial ones (Claude, GPT-5) — without managing GPUs.
#
# If set, OpenClaw is automatically configured with all 29 models.
# The default is openai-gpt-oss-120b. You can switch models
# anytime via the UI dashboard.
#
# If left blank, no provider is pre-configured. You can set up
# any provider (Anthropic, OpenAI, OpenRouter, etc.) via the
# UI after deployment.
#
# How to get it:
#   1. Log in to https://cloud.digitalocean.com
#   2. Go to AI / ML → Gradient AI (left sidebar)
#   3. Click "Create API Key" (or "Manage Keys")
#   4. Copy the key — it starts with sk-do-
#
# Pricing: All models are billed per-token via your DO account.
# See: https://docs.digitalocean.com/products/ai-ml/gradient-ai/details/pricing/
#
GRADIENT_API_KEY=


# ─── Droplet Config (optional — for non-interactive mode) ───────
# Set these to skip interactive prompts during install.
# Useful for AI agents and CI/CD pipelines.
#
# DROPLET_REGION=fra1
# DROPLET_SIZE=s-2vcpu-4gb
# DROPLET_SSH_KEY_IDS=12345,67890






# ─── Timezone (optional) ────────────────────────────────────────
# Your local timezone for scheduled tasks and heartbeats.
# Uses IANA timezone names: Europe/Berlin, US/Eastern, Asia/Tokyo
# Default: UTC
#
TZ=UTC


# ─── Telegram Channel (optional) ────────────────────────────────
# Telegram bot token from @BotFather.
#
# How to create:
#   1. Open Telegram → search @BotFather
#   2. Send /newbot → follow prompts
#   3. Copy the token (e.g., 123456:ABC-DEF...)
#
TELEGRAM_BOT_TOKEN=

# ─── Discord Channel (optional) ─────────────────────────────────
# Discord bot token for the Discord channel integration.
#
# How to create a bot:
#   1. Go to https://discord.com/developers/applications
#   2. Click "New Application" → name it (e.g., "glossgo AI")
#   3. Go to Bot tab → click "Reset Token" → copy the token
#   4. Enable "Message Content Intent" under Privileged Gateway Intents
#   5. Go to OAuth2 → URL Generator → select "bot" + "applications.commands"
#   6. Select permissions: Send Messages, Read Message History, Add Reactions
#   7. Copy the generated URL and open it to invite the bot to your server
#
DISCORD_BOT_TOKEN=

# ─── WhatsApp Channel (optional) ────────────────────────────────
# Set WHATSAPP_ENABLED=true to activate WhatsApp via Baileys.
# After deployment, open the Control UI and scan the QR code
# with WhatsApp on your phone to pair the session.
#
# WHATSAPP_ALLOW_FROM: comma-separated E.164 phone numbers
# that are allowed to DM the bot. Leave empty for pairing mode.
#
WHATSAPP_ENABLED=false
WHATSAPP_ALLOW_FROM=

# ═══════════════════════════════════════════════════════════════════
# YOUR APP-SPECIFIC VARIABLES
# ═══════════════════════════════════════════════════════════════════
# Add your project's environment variables below. These will be
# available to your Docker container at runtime.
#
# Examples:
#   OPENAI_API_KEY=sk-...
#   ANTHROPIC_API_KEY=sk-ant-...
#   DATABASE_URL=postgresql://...
#   MY_CUSTOM_VAR=hello
#
