# ═══════════════════════════════════════════════════════════════════
# 🦞 Git Ignore — keep secrets out of version control
# ═══════════════════════════════════════════════════════════════════

# ─── Secrets (MOST IMPORTANT) ───────────────────────────────────
# .env contains API keys. NEVER commit it.
# Even if you git rm later, the keys remain in commit history forever.
.env
*.env.local
*.env.production

# Keep the template (it has no real secrets)
!example.env

# ─── Docker runtime ─────────────────────────────────────────────
docker-compose.override.yml

# ─── OS junk ────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Python ─────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ─── Node ───────────────────────────────────────────────────────
node_modules/

# ─── Editor ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
